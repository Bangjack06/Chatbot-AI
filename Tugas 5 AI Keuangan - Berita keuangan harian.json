      "name": "Basic LLM Chain",
      "retryOnFail": true
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const text = item.json.text || '';\n\n  // bersihin spasi berlebih\n  const clean = text.replace(/\\s+/g, ' ').trim();\n\n  // ambil 2–3 kalimat pertama (lead berita)\n  const sentences = clean.split('. ');\n  const important = sentences.slice(0, 3).join('. ') + '.';\n\n  return {\n    json: {\n      text: important.slice(0, 500) // limit biar hemat\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
